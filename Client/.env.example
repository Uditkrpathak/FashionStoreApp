# Local Development (iOS Simulator): EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
# Production APK Build: EXPO_PUBLIC_API_URL=https://<your-render-gateway-url>/api/v1
EXPO_PUBLIC_API_URL=https://<your-render-gateway-url>/api/v1

